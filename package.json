{
  "name": "delf_timer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/write-dist-root-index.mjs",
    "web:github": "npm run build && node scripts/prepare-github-web.mjs",
    "dist": "npm run tauri:build",
    "dist:win": "npm run tauri:build",
    "dist:win:single": "npm run tauri:build",
    "live": "npm run build && live-server dist/web --host=127.0.0.1 --port=5500 --no-browser",
    "desktop": "npm run tauri:dev",
    "desktop:fast": "npm run tauri:dev",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "javascript-obfuscator": "^4.1.1",
    "live-server": "^1.2.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "build": {}
}
